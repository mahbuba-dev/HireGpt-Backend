{
  "name": "consultedge-backend",
  "version": "1.0.0",
  "description": "",
  "main": "api/server.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/index.ts src/server.ts --format esm --platform node --target node20 --outDir api --external pg-native",
    "start": "node api/server.js",
    "seed": "tsx prisma/seed.ts prisma/seed-demo.json",
    "seed:file": "tsx prisma/seed.ts",
    "seed:transform": "tsx prisma/seed-transform.ts",
    "seed:refresh:experts": "tsx prisma/refresh-seeded-experts.ts",
    "seed:refresh:industries": "tsx prisma/refresh-seeded-industries.ts",
    "seed:refresh:slots": "tsx prisma/refresh-seeded-expert-slots.ts",
    "seed:refresh:review-clients": "tsx prisma/refresh-seeded-review-clients.ts",
    "seed:refresh:testimonials": "tsx prisma/refresh-seeded-testimonials.ts",
    "experts:cleanup-broken": "tsx prisma/cleanup-broken-experts.ts",
    "deploy:prepare": "npx prisma migrate deploy && (npm run seed:refresh:slots || echo 'WARN: seeded slot refresh failed (non-fatal); deploy continuing')",
    "service:up": "npm run build && npm run deploy:prepare && pm2 start ecosystem.config.cjs --env production --update-env && pm2 save",
    "service:restart": "pm2 restart consultedge-backend --update-env && pm2 save",
    "service:logs": "pm2 logs consultedge-backend",
    "postinstall": "prisma generate",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "studio": "prisma studio",
    "push": "prisma db push",
    "pull": "prisma db pull",
    "stripe:webhook": "stripe listen --forward-to localhost:5000/webhook"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^7.3.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/multer": "^2.0.0",
    "ably": "^2.21.0",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.4.17",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "git-filter-repo": "^0.0.30",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "multer": "^2.1.0",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.13",
    "openai": "^6.37.0",
    "pg": "^8.17.2",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}

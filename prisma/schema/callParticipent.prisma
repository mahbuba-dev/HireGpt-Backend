model CallParticipant {
  id        String        @id @default(uuid())
  callId    String
  userId    String
  role      UserRole
  joinedAt  DateTime?
  leftAt    DateTime?
  aiScore   Float?
  createdAt DateTime      @default(now())
  call      InterviewCall @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@index([userId])
  @@map("call_participants")
}

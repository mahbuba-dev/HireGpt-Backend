model UserPresence {
  userId     String   @id
  isOnline   Boolean  @default(false)
  lastSeen   DateTime @default(now())
  lastAction String?
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isOnline])
  @@map("user_presence")
}

NODE_ENV=production
PORT=5000

# PostgreSQL direct connection URL (not pooler) for long-running server
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Better Auth
BETTER_AUTH_URL=https://api.yourdomain.com
BETTER_AUTH_SECRET=replace-with-strong-32char-secret

# JWT
ACCESS_TOKEN_SECRET=replace-me
REFRESH_TOKEN_SECRET=replace-me
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=7d

# SMTP
EMAIL_SENDER_SMTP_USER=
EMAIL_SENDER_SMTP_PASSWORD=
EMAIL_SENDER_SMTP_HOST=smtp.gmail.com
EMAIL_SENDER_SMTP_PORT=465
EMAIL_SENDER_SMTP_FROM=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/auth/callback/google

# Frontend
FRONTEND_URL=https://yourdomain.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin seed
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMeStrong123!

ABLY_API_KEY=your-ably-api-key

# ---------- AI Module (Phase 2) ----------
# Provider auto-resolves: dev -> gemini, prod -> openai. Override here if needed.
OPENAI_API_KEY=sk-your-openai-api-key
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

OPENAI_MODEL=gpt-4o-mini

# ---------- Demo accounts (auto-seeded on first demo login) ----------
DEMO_CLIENT_EMAIL=client@consultedge.demo
DEMO_CLIENT_PASSWORD=Demo@12345
DEMO_CLIENT_NAME=Demo Client

DEMO_EXPERT_EMAIL=expert@consultedge.demo
DEMO_EXPERT_PASSWORD=Demo@12345
DEMO_EXPERT_NAME=Demo Expert

DEMO_ADMIN_EMAIL=admin@consultedge.demo
DEMO_ADMIN_PASSWORD=Demo@12345
DEMO_ADMIN_NAME=Demo Admin
